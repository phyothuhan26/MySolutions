@startuml
title G&G Revamp - C4 Level 3 Component Diagram (YPS Service Container)

left to right direction
skinparam componentStyle rectangle
skinparam shadowing false
skinparam packageStyle rectangle

package "YPS Service Container" {

  component "Push Money API\n<<interface>>" as PushMoney
  component "CSV Import Component\n<<interface>>" as CsvImport

  component "Sale Publish Component\n<<business>>" as Publish
  component "Shift Validation Component\n<<business>>" as ShiftValidation

  component "Scheduler Component\n<<support>>" as Scheduler
  component "Notification Component\n<<support>>" as Notification

  component "Data Access Component\n<<persistence>>" as DataAccess

  queue "Message Broker\nRabbitMQ / Kafka" as MQ
  database "Redis Cache\n(Bill, Product, Store)" as Redis
  database "G&G Database\nReference Data" as GGDB
  database "YPS Database\nImport & Session Records" as YPSDB
}

rectangle "G&G Backend\n<<external system>>" as Backend

PushMoney --> Publish
CsvImport --> Publish
CsvImport --> Notification
CsvImport --> DataAccess

Scheduler --> CsvImport
Scheduler --> ShiftValidation

ShiftValidation --> DataAccess
Publish --> DataAccess

Publish --> Redis
Publish --> MQ

Notification --> Backend

DataAccess --> GGDB
DataAccess --> YPSDB

@enduml